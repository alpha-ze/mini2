# Classifier Mode Configuration
# Options: "distilbert" (FREE), "openai" (Paid), "anthropic" (Paid), "auto" (tries API first, falls back to DistilBERT)
CLASSIFIER_MODE=auto

# AI Provider Configuration (for API-based classification)
AI_PROVIDER=openai  # or "anthropic"

# HuggingFace Configuration (for DistilBERT mode)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Configuration (if using Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Settings
CONFIDENCE_THRESHOLD=0.7
SIMILARITY_THRESHOLD=0.85
TIME_WINDOW_HOURS=72

# Optional: Model Paths (for custom models)
MODEL_PATH=./models/classifier
SLA_MODEL_PATH=./models/sla_predictor.pkl
